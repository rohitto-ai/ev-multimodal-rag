# ══════════════════════════════════════════════════════════════════════════════
# EV Multimodal RAG System — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:      cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit the .env file to Git (it is in .gitignore)
#
# Get your FREE Gemini API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1M tokens/day — sufficient for this project.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key (used for both LLM answer generation and VLM image summarisation)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Gemini model to use. gemini-1.5-flash is fastest and free-tier friendly.
# Options: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Local sentence-transformer model for embeddings (downloaded on first run, ~90 MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB persistent storage directory (created automatically if absent)
CHROMA_PERSIST_DIR=./chroma_db

# ChromaDB collection name
COLLECTION_NAME=ev_rag_multimodal

# Text chunk size in characters
CHUNK_SIZE=1500

# Overlap between consecutive text chunks in characters
CHUNK_OVERLAP=200

# Number of chunks to retrieve per query
TOP_K=5

# Maximum PDF upload size in megabytes
MAX_FILE_SIZE_MB=50
